# 复制为 .env 后填写真实密钥（不要将 .env 提交到版本库）

# 独立前端调本 API 时的基址（浏览器端配置，后端 .env 可不设）
# RESEARCH_API_BASE=http://127.0.0.1:8000
# SEC EDGAR：须设置可识别 User-Agent（含联系邮箱），见 https://www.sec.gov/os/accessing-edgar-data
# 亦为 8-K 附件逐字稿抓取（data.sec.gov + Archives）及 Form 4 等所必需
# SEC_EDGAR_USER_AGENT=YourOrg/1.0 (you@example.com)

# Anthropic（优先 LLM）：板块「业务构成分布」用 ANTHROPIC_MODEL；行业报告内 task=finance 的调用用 ANTHROPIC_MODEL_FINANCE（未设则同默认）
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL_FINANCE=claude-opus-4-6

# 可选：sec-api.io — Full-Text Search 检索 8-K 附件（免费层约 100 次/日）；未设置时跳过该来源
# SEC_API_KEY=
OPENAI_API_KEY=sk-your-key-here

# 新闻隔夜/昨日总结时间窗所用 IANA 时区（默认 America/New_York）
NEWS_TIMEZONE=America/New_York

# 公司新闻（晨报/隔夜/昨日总结与 RSS 合并）：优先 Benzinga News API v2，失败或为空时回退 Finnhub
# Benzinga：https://www.benzinga.com/apis/ — 注册后在控制台创建 API Key（查询参数 token）
# BENZINGA_API_KEY=

# 可选：Finnhub 公司新闻兜底；免费层约 60 次/分钟、每月 1000 次（无 Benzinga 或 Benzinga 无结果时使用）
# FINNHUB_API_KEY=

# 可选：DigitalOcean PostgreSQL（Mac 端 bloomberg_reader 只读 bloomberg schema；ETL 在服务端）
# DO_DB_HOST=
# DO_DB_PORT=25060
# DO_DB_NAME=defaultdb
# DO_DB_USER=
# DO_DB_PASSWORD=
# DO_DB_SSLMODE=require
# 本地/VPN 连不上 DO 时设为 0，财务等走 FMP/SEC，避免长时间超时
# BLOOMBERG_DB_ENABLED=0
# 单次连接超时（秒），默认 8
# DO_DB_CONNECT_TIMEOUT=8

# 可选：Financial Modeling Prep — 标准化年报财务（营收/EBITDA/毛利率/Capex/净负债权益）；未设置时财务服务回退 SEC
# 财报电话会逐字稿接口多为付费层：免费 key 常见 HTTP 402，将回退 EDGAR 8-K / sec-api 等链路
# 客户端使用 https://financialmodelingprep.com/stable/...（新密钥对旧 /api/v3/ 常 403）
# FMP_API_KEY=

# 行业报告：新闻 relevance_score 下限（0–3，默认 1）
# REPORT_RELEVANCE_THRESHOLD=1

# 行业报告调试：设为 1 时板块级 LLM 失败不吞异常（便于看完整栈）
# SECTOR_REPORT_STRICT_LLM=1

